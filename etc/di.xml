<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Product Index resource model -->
    <type name="Byte8\Horizon\Model\ProductIndex">
        <arguments>
            <argument name="resource" xsi:type="object">Byte8\Horizon\Model\ResourceModel\ProductIndex</argument>
        </arguments>
    </type>

    <!-- CLI commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="horizon_reindex" xsi:type="object">Byte8\Horizon\Console\Command\ReindexCommand</item>
            </argument>
        </arguments>
    </type>

    <!-- MSI (Multi-Source Inventory) hooks. MSI is plugin-driven, not event-
         driven, so we attach after-plugins to its public service interfaces.
         These plugins silently no-op when MSI isn't installed. -->
    <type name="Magento\InventoryApi\Api\SourceItemsSaveInterface">
        <plugin name="byte8_horizon_msi_source_items_save"
                type="Byte8\Horizon\Plugin\Msi\SourceItemsSavePlugin"
                sortOrder="100"/>
    </type>
    <type name="Magento\InventoryApi\Api\SourceItemsDeleteInterface">
        <plugin name="byte8_horizon_msi_source_items_delete"
                type="Byte8\Horizon\Plugin\Msi\SourceItemsDeletePlugin"
                sortOrder="100"/>
    </type>

</config>
